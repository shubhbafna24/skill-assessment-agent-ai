# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/skill_agent"

# AI Provider — default is groq (free tier, no credit card needed)
# Options: groq | openrouter | openai | gemini
AI_PROVIDER="groq"

# Get a free Groq key at https://console.groq.com
GROQ_API_KEY="gsk_..."

# Other provider keys (only needed if you change AI_PROVIDER above)
OPENROUTER_API_KEY=""
OPENAI_API_KEY=""
GEMINI_API_KEY=""
